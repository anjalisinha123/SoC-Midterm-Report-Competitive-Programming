#include <bits/stdc++.h>
using namespace std;
 
int main(){
    string s, t;
    cin >> s >> t;
    for(int i=0; i < s.size(); i++){
        if(s[i] >= 'A' && s[i] <= 'Z') s[i] += 32;
        if(t[i] >= 'A' && t[i] <= 'Z') t[i] += 32;
    }
    if(s > t) cout << 1;
    else if(s < t) cout << -1;
    else cout << 0;
    return 0;
}
