#include <bits/stdc++.h>
using namespace std;
 
int main() {
    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        vector<int> a(n);
        for (int i = 0; i < n; i++) cin >> a[i];
 
        int min_pos = min_element(a.begin(), a.end()) - a.begin();
        int max_pos = max_element(a.begin(), a.end()) - a.begin();
 
        int left  = min(min_pos, max_pos);
        int right = max(min_pos, max_pos);
 
        int opt1 = right + 1;         // both from left
        int opt2 = n - left;          // both from right
        int opt3 = (left + 1) + (n - right); // one from each side
 
        cout << min({opt1, opt2, opt3}) << "\n";
    }
    return 0;
}
